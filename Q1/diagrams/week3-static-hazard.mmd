flowchart LR
    A["A"] --> G1["AND<br/>AB"]
    B["B"] --> G1
    A --> INV["NOT"]
    INV --> G2["AND<br/>A' C"]
    C["C"] --> G2
    G1 --> OR["OR"]
    G2 --> OR
    OR --> F["F = AB + A' C"]
    B -.-> G3["optional AND<br/>consensus BC"]
    C -.-> G3
    G3 -.-> OR

    classDef signal fill:#e8f0fe,stroke:#1a73e8,color:#174ea6
    classDef gate fill:#fff4e5,stroke:#f29900,color:#7a4b00
    classDef fix fill:#fce8e6,stroke:#d93025,color:#8c1d18
    classDef result fill:#e6f4ea,stroke:#188038,color:#0d652d
    class A,B,C signal
    class INV,G1,G2,OR gate
    class G3 fix
    class F result
